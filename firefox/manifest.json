{
    "name": "__MSG_application_title__",
    "description": "__MSG_application_description__",
    "version": "2.0",
    "default_locale": "en",
    "icons": {
        "16": "assets/img/icon_16.png",
        "32": "assets/img/icon_32.png",
        "48": "assets/img/icon_48.png",
        "64": "assets/img/icon_64.png",
        "128": "assets/img/icon_128.png"
    },
    "manifest_version": 3,
    "permissions": ["history", "tabs", "storage"],
    "host_permissions": ["file:///*", "*://*/*"],
    "browser_specific_settings": {
        "gecko": {
            "id": "dragon-better-history@awsms.github.io"
        }
    },
    "background": {
        "scripts": ["background.js"]
    },
    "commands": {
        "open-history-dashboard": {
            "suggested_key": {
                "default": "Ctrl+Shift+H"
            },
            "description": "Open Better History"
        }
    },
    "action": {
        "default_icon": {
            "16": "assets/img/icon_16.png",
            "32": "assets/img/icon_32.png"
        },
        "default_title": "__MSG_application_title__",
        "default_popup": "popup.html"
    }
}
